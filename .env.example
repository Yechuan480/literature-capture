# 可选：覆盖 config.yaml 中的文献根目录
# LITERATURE_ROOT=/Users/book/Desktop/Aqueous literature

# 可选：AI 视觉补强的初始默认值（也可在网页「AI 设置」中填写，优先使用网页保存）
# LITERATURE_AI_API_KEY=sk-...
# LITERATURE_AI_ENABLED=false

# 补充材料 SI（也可在 config.yaml 的 si: 块配置）
# LITERATURE_SI_ENABLED=true
# LITERATURE_SI_AUTO_ON_OPEN=true
# LITERATURE_SI_CROSSREF_MAILTO=you@example.com
